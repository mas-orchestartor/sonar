# =============================================================
# Пример переменных окружения для запуска БЕЗ Coolify
# (docker compose --env-file .env up -d).
#
# В Coolify этот файл не нужен: переменные SERVICE_* Coolify
# генерирует сам, а остальные появятся в UI (Environment
# Variables) со значениями по умолчанию — их можно менять там.
# =============================================================

# --- Эти переменные в Coolify создаются автоматически ---------
# Полный публичный URL SonarQube (в Coolify берётся из поля Domains)
SERVICE_URL_SONARQUBE=http://localhost:9000
# Логин/пароль PostgreSQL
SERVICE_USER_POSTGRES=sonar
SERVICE_PASSWORD_POSTGRES=change-me-strong-password

# --- Настраиваемые параметры ----------------------------------
# Тег образа sonarqube: community (последний Community Build),
# 25.7.0.110598-community (фиксированная версия), developer, enterprise
SONARQUBE_VERSION=community

# Тег образа postgres
POSTGRES_VERSION=17-alpine

# Имя базы данных
POSTGRES_DB=sonar

# true  — SonarQube стартует без vm.max_map_count=524288 на хосте
# false — требует sysctl на хосте, но Elasticsearch стабильнее (прод)
SONAR_ES_BOOTSTRAP_CHECKS_DISABLE=true

# Память JVM. Суммарно контейнеру нужно ~2 ГБ при значениях ниже.
SONAR_WEB_JAVAOPTS=-Xmx512m -Xms128m
SONAR_CE_JAVAOPTS=-Xmx512m -Xms128m
SONAR_SEARCH_JAVAOPTS=-Xmx512m -Xms512m

# Телеметрия SonarSource
SONAR_TELEMETRY_ENABLE=false
